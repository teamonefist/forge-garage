#!/usr/bin/env bash
set -euo pipefail

GARAGE_HOME="${HOME}/.forge-garage"
RUN_DIR="${GARAGE_HOME}/run"

echo "=== Forge Garage Stop ==="

stop_process() {
    local name="$1"
    local pidfile="${RUN_DIR}/${name}.pid"

    if [[ -f "${pidfile}" ]]; then
        local pid
        pid=$(cat "${pidfile}")
        if kill -0 "${pid}" 2>/dev/null; then
            echo "[${name}] Stopping PID ${pid}..."
            kill "${pid}"
            sleep 2
            if kill -0 "${pid}" 2>/dev/null; then
                echo "[${name}] Force killing..."
                kill -9 "${pid}" 2>/dev/null || true
            fi
            echo "[${name}] Stopped."
        else
            echo "[${name}] Not running (stale PID file)."
        fi
        rm -f "${pidfile}"
    else
        echo "[${name}] No PID file found."
    fi
}

stop_process "orchestrator"
stop_process "warrior"

echo ""
echo "All backends stopped."
