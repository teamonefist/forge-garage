#!/usr/bin/env bash
set -euo pipefail

GARAGE_HOME="${HOME}/.forge-garage"
RUN_DIR="${GARAGE_HOME}/run"

if [[ ! -d "${GARAGE_HOME}" ]]; then
    echo "Error: ${GARAGE_HOME} not found. Run install.sh first."
    exit 1
fi

mkdir -p "${RUN_DIR}" "${GARAGE_HOME}/logs"

PERSONA="${1:-orchestrator}"
PERSONA=$(echo "$PERSONA" | tr '[:upper:]' '[:lower:]')

if [[ "$PERSONA" != "orchestrator" && "$PERSONA" != "warrior" ]]; then
    echo "Usage: forge-garage-start [orchestrator|warrior]"
    echo "  Default: orchestrator"
    exit 1
fi

model_path=$(python3 -c "import yaml; print(yaml.safe_load(open('${GARAGE_HOME}/config.yml'))['${PERSONA}']['model_path'])" 2>/dev/null)
port=$(python3 -c "import yaml; print(yaml.safe_load(open('${GARAGE_HOME}/config.yml'))['${PERSONA}']['port'])" 2>/dev/null || echo 8081)

model_path="${model_path/#\~/$HOME}"

echo "=== Forge Garage — Single GPU Mode ==="
echo ""

# Stop any running model first
for p in orchestrator warrior; do
    PID_FILE="${RUN_DIR}/${p}.pid"
    if [[ -f "$PID_FILE" ]]; then
        OLD_PID=$(cat "$PID_FILE")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            echo "Stopping ${p} (PID ${OLD_PID})..."
            kill "$OLD_PID" 2>/dev/null || true
            sleep 2
            kill -0 "$OLD_PID" 2>/dev/null && kill -9 "$OLD_PID" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
    fi
done

if curl -s "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
    echo "[${PERSONA}] Already running on port ${port}"
    exit 0
fi

echo "[${PERSONA}] Starting on port ${port}..."
echo "  Model: ${model_path}"

LORA_FILE="${GARAGE_HOME}/models/forge-${PERSONA}-lora-f16.gguf"
LORA_ARG=""
if [[ -f "$LORA_FILE" ]]; then
    LORA_ARG="--lora ${LORA_FILE}"
    echo "  LoRA: ${LORA_FILE}"
fi

nohup llama-server \
    --model "${model_path}" \
    ${LORA_ARG} \
    --port "${port}" \
    --host 127.0.0.1 \
    --ctx-size 32768 \
    --n-gpu-layers -1 \
    --threads 8 \
    --parallel 1 \
    --cont-batching \
    --flash-attn on \
    --mlock \
    > "${GARAGE_HOME}/logs/${PERSONA}.log" 2>&1 &
echo $! > "${RUN_DIR}/${PERSONA}.pid"
echo "  PID: $(cat ${RUN_DIR}/${PERSONA}.pid)"

echo ""
echo "Waiting for health check..."
for i in $(seq 1 120); do
    if curl -s "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
        echo "${PERSONA} is ready."
        exit 0
    fi
    printf "."
    sleep 2
done

echo ""
echo "Warning: ${PERSONA} not healthy after 240s."
echo "Check logs: ${GARAGE_HOME}/logs/${PERSONA}.log"
