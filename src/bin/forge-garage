#!/usr/bin/env bash
set -euo pipefail

GARAGE_HOME="${HOME}/.forge-garage"
VENV="${GARAGE_HOME}/venv"

if [[ ! -d "${GARAGE_HOME}" ]]; then
    echo "Error: ${GARAGE_HOME} not found. Run install.sh first."
    exit 1
fi

# Activate venv and run TUI (model swapping handled by Python)
source "${VENV}/bin/activate"
export PYTHONPATH="${GARAGE_HOME}"
python3 -m lib.app
